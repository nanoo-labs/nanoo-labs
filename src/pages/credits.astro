---
import PageLayout from "@layouts/PageLayout.astro";
import Container from "@components/Container.astro";
import Link from "@components/Link.astro";

const CREDITS = [
  {
    NAME: "Astro Nano",
    DESCRIPTION: "The original minimalist theme this site is built upon.",
    HREF: "https://github.com/markhorn-dev/astro-nano",
  },
  {
    NAME: "Astro",
    DESCRIPTION: "The web framework for content-driven websites.",
    HREF: "https://astro.build",
  },
  {
    NAME: "Tailwind CSS",
    DESCRIPTION: "A utility-first CSS framework for rapid UI development.",
    HREF: "https://tailwindcss.com",
  },
  {
    NAME: "TypeScript",
    DESCRIPTION: "Ensuring code reliability with static typing.",
    HREF: "https://www.typescriptlang.org",
  },
  {
    NAME: "Geist Sans",
    DESCRIPTION: "Modern typography designed by Vercel for technical interfaces.",
    HREF: "https://vercel.com/font/sans",
  },
  {
    NAME: "FontAwesome",
    DESCRIPTION: "The source for the solid and iconic SVG icons.",
    HREF: "https://fontawesome.com",
  },
  {
    NAME: "Zod",
    DESCRIPTION: "TypeScript-first schema validation for content collections.",
    HREF: "https://zod.dev",
  },
  {
    NAME: "Sharp",
    DESCRIPTION: "High-performance image processing for optimized assets.",
    HREF: "https://sharp.pixelplumbing.com",
  },
  {
    NAME: "pnpm",
    DESCRIPTION: "A fast, disk space efficient package manager.",
    HREF: "https://pnpm.io",
  },
  {
    NAME: "Prettier",
    DESCRIPTION: "Keeping the codebase clean and consistently formatted.",
    HREF: "https://prettier.io",
  }
];
---

<PageLayout title="Credits" description="The tools and technologies that power this website.">
  <Container>
    <div class="space-y-10">
      <div class="animate font-semibold text-black dark:text-white">Credits</div>
      <p class="animate">
        This project is made possible by the incredible open-source community and 
        the following technologies:
      </p>
      <ul class="flex flex-col space-y-8">
        {
          CREDITS.map((credit) => (
            <li class="animate">
              <div class="space-y-1">
                <Link href={credit.HREF} external class="font-semibold text-black dark:text-white">
                  {credit.NAME}
                </Link>
                <div class="text-sm opacity-75">
                  {credit.DESCRIPTION}
                </div>
              </div>
            </li>
          ))
        }
      </ul>
      <p class="animate text-sm italic">
        And special thanks to you for visiting this site.
      </p>
    </div>
  </Container>
</PageLayout>
