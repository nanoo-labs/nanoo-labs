---
import PageLayout from "@layouts/PageLayout.astro";
import Container from "@components/Container.astro";
import { CONTRIBUTOR } from "@consts";

//  contributor variable
const contributors = [
  {
    name: "aadnanmt",
    role: "Maintainer",
    img: "https://avatars.githubusercontent.com/u/199176689?s=96&v=4",
  },
  {
    name: "zaagraphite",
    role: "Designer",
    img: "test",
  },
];
---

<PageLayout title={CONTRIBUTOR.TITLE} description={CONTRIBUTOR.DESCRIPTION}>
  <Container>
    <div class="space-y-10">
      <div class="animate font-semibold text-black dark:text-white">
        <h1 class="text-3xl font-bold text-black dark:text-white">
          Contributors
        </h1>
      </div>

      <div class="animate space-y-4">
        <p class="opacity-75">
          Thanks to the individuals who have helped develop this project
        </p>
        <ul class="flex flex-col gap-4">
          {
            contributors.map((person) => (
              <li class="flex items-center gap-4 rounded-lg border border-black/15 p-4 transition-colors hover:bg-black/5 dark:border-white/25 dark:hover:bg-white/5">
                <div class="flex h-12 w-12 shrink-0 items-center justify-center rounded-full bg-cyan-400/20 font-bold text-cyan-700 dark:text-cyan-400">
                  <img src={person.img} />
                </div>
                <div>
                  <div class="font-semibold text-black dark:text-white">
                    {person.name}
                  </div>
                  <div class="text-sm opacity-75">{person.role}</div>
                </div>
              </li>
            ))
          }
        </ul>
      </div>

      <section class="animate space-y-4">
        <h2 class="font-semibold text-black dark:text-white">
          Want to Contribute?
        </h2>
      </section>
    </div>
  </Container>
</PageLayout>
